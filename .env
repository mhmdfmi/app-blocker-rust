# App Blocker Environment Configuration
# DO NOT SHARE THIS FILE

# Security - Password hash (default: admin123)
# Use: argon2 hash generator to create your own
ADMIN_PASSWORD_HASH=$argon2i$v=19$m=4096,t=3,p=1$YXBwX2Jsb2NrZXI$abcdef1234567890

# App Configuration
APP_NAME=AppBlocker
APP_VERSION=1.0.0
LOG_LEVEL=INFO

# Simulation Mode (dev only)
SIMULATION_MODE=true
SIMULATE_PROCESS_KILL=true
SIMULATE_OVERLAY=true
LOG_ONLY_MODE=true

# Monitoring
MONITOR_INTERVAL_MS=1000
VALIDATION_DELAY_MS_MIN=300
VALIDATION_DELAY_MS_MAX=1000
RATE_LIMIT_PER_MINUTE=3

# Overlay
OVERLAY_TITLE=Peringatan Keamanan
OVERLAY_MESSAGE=Aplikasi terlarang terdeteksi dan telah ditutup.
OVERLAY_FAILSAFE_MINUTES=30

# Security
MAX_AUTH_ATTEMPTS=5
LOCKOUT_DURATION_SECONDS=300
MEMORY_ZEROING=true
