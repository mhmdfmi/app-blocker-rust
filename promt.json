{
    "role": "Senior Rust Systems Engineer",
    "meta": {
        "version": "1.0.0",
        "environment": "production",
        "last_updated": "2026-04-16",
        "author": "Muhamad Fahmi",
        "compatibility": ["Rust 1.94.0", "Windows 10/11"]
    },
    "constraints": [
        "do_not_kill_protected_processes",
        "do_not_damage_os",
        "full_recovery_required",
        "thread_safe",
        "production_ready"
    ],
    "ai_guardrails": {
        "forbidden_behaviors": [
            "skip_error_handling",
            "ignore_thread_safety",
            "use_unwrap",
            "use_blocking_calls_in_async_context",
            "kill_system_process"
        ],
        "required_behaviors": [
            "validate_every_action",
            "log_every_decision",
            "fail_safe_on_error",
            "prefer_safe_over_aggressive"
        ]
    },
    "domain_constraints": {
        "never_block_during": ["system_boot", "windows_update"],
        "max_overlay_duration_minutes": 60,
        "max_cpu_usage_percent": 30
    },
    "environment": {
        "os": "Windows 10/11",
        "rust_version": "1.94.1"
    },
    "extensibility": {
        "plugin_system": {
            "enabled": true,
            "load_dynamic_modules": false,
            "future_ready": true
        }
    },
    "objective": {
        "name": "app_blocker",
        "description": "Production-ready Windows App Blocker with real-time monitoring, secure process termination, overlay lock UI, authentication, and audit logging",
        "requirements": [
            "real_time_monitoring",
            "blacklist_detection",
            "safe_process_termination",
            "fullscreen_overlay_lock",
            "admin_password_unlock",
            "secure_logging",
            "safe_recovery",
            "tx_rx_multithreading"
        ],
        "project_structure": {
            "type": "strict",
            "enforce_exact_structure": true,
            "root": "app_blocker",
            "tree": [
                "Cargo.toml",
                "Cargo.lock",
                ".env",
                ".gitignore",
                "README.md",
                "CHANGELOG.md",
                "LICENSE",

                "config/default.toml",
                "config/production.toml",

                "logs/",
                "reports/",

                "scripts/install_service.ps1",
                "scripts/uninstall_service.ps1",

                "src/main.rs",
                "src/lib.rs",

                "src/core/mod.rs",
                "src/core/monitor.rs",
                "src/core/engine.rs",
                "src/core/state.rs",
                "src/core/events.rs",

                "src/ui/mod.rs",
                "src/ui/overlay.rs",
                "src/ui/window.rs",
                "src/ui/input.rs",
                "src/ui/components.rs",

                "src/security/mod.rs",
                "src/security/auth.rs",
                "src/security/encryption.rs",
                "src/security/memory.rs",
                "src/security/integrity.rs",

                "src/system/mod.rs",
                "src/system/process.rs",
                "src/system/user.rs",
                "src/system/service.rs",
                "src/system/hooks.rs",

                "src/utils/mod.rs",
                "src/utils/logger.rs",
                "src/utils/error.rs",
                "src/utils/time.rs",
                "src/utils/retry.rs",

                "src/config/mod.rs",
                "src/config/settings.rs",
                "src/config/env_loader.rs",
                "src/config/validator.rs",

                "src/constants/mod.rs",
                "src/constants/messages.rs",
                "src/constants/paths.rs",

                "src/tests/mod.rs",
                "src/tests/auth_tests.rs",
                "src/tests/engine_tests.rs",
                "src/tests/state_tests.rs"
            ],
            "rules": [
                "do_not_modify_structure",
                "do_not_omit_files",
                "all_files_must_be_generated",
                "respect_module_hierarchy"
            ]
        }
    },
    "deployment": {
        "mode": ["development", "production"],
        "feature_flags": true,
        "dry_run_mode": true,
        "simulation_mode": {
            "enabled": true,
            "simulate_process_kill": true,
            "simulate_overlay": true,
            "log_only_mode": true
        }
    },
    "execution_contract": {
        "strict_mode": true,
        "no_assumption_allowed": true,
        "no_feature_skipping": true,
        "must_follow_all_sections": true,
        "fail_if_uncertain": true,
        "deterministic_output": true,
        "step_by_step_generation": true,
        "self_validation_required": true,
        "regenerate_on_violation": true
    },
    "architecture": {
        "concurrency": {
            "channel": "std::sync::mpsc",
            "shared_state": "Arc<RwLock<AppState>>",
            "state_machine": [
                "Monitoring",
                "Blocking",
                "Locked",
                "Recovering",
                "SafeMode"
            ],
            "rules": [
                "atomic_state_transition",
                "no_long_locks",
                "no_lock_during_io",
                "no_lock_during_kill",
                "no_lock_during_ui"
            ],
            "build_rules": {
                "must_compile": true,
                "deny_warnings": true,
                "clippy_clean": true,
                "format_with_rustfmt": true
            },
            "build": {
                "release_flags": ["-C opt-level=3", "-C lto=true"],
                "strip_symbols": true,
                "panic": "abort"
            },
            "channel_resilience": {
                "detect_disconnect": true,
                "auto_recreate_channel": true,
                "fallback_mode": "safe_mode"
            }
        },
        "threads": {
            "monitor_thread": {
                "role": "TX",
                "responsibilities": [
                    "scan_processes",
                    "apply_validation_delay",
                    "check_blacklist",
                    "check_whitelist",
                    "rate_limit",
                    "safe_kill",
                    "send_event"
                ]
            },
            "ui_thread": {
                "role": "RX",
                "responsibilities": [
                    "receive_event",
                    "launch_overlay",
                    "block_until_unlock",
                    "reset_state",
                    "log_event",
                    "resume_monitoring"
                ]
            },
            "watchdog_thread": {
                "responsibilities": [
                    "monitor_overlay",
                    "monitor_threads",
                    "restart_failed_components"
                ]
            }
        },
        "state_validation": {
            "enabled": true,
            "validate_before_transition": true,
            "on_invalid": ["reset_state", "enter_safe_mode"]
        },
        "state_invariants": {
            "Monitoring": ["is_locked == false", "is_safe_to_block == false"],
            "Blocking": ["is_safe_to_block == false", "is_locked == false"],
            "Locked": ["is_locked == true", "overlay_active == true"],
            "Recovering": ["is_locked == false", "cleanup_in_progress == true"],
            "SafeMode": ["blocking_disabled == true"]
        },
        "state_transition_rules": {
            "allowed_transitions": [
                "Monitoring -> Blocking",
                "Blocking -> Locked",
                "Locked -> Recovering",
                "Recovering -> Monitoring",
                "any -> SafeMode"
            ],
            "forbidden_transitions": [
                "Monitoring -> Locked",
                "Locked -> Monitoring"
            ]
        },
        "threading_contract": {
            "required_threads": ["monitor", "ui", "watchdog"],
            "communication": {
                "channel_type": "mpsc",
                "message_types": [
                    "ProcessDetected",
                    "ProcessKilled",
                    "TriggerOverlay",
                    "UnlockSuccess",
                    "Shutdown"
                ]
            },
            "lifecycle": {
                "graceful_shutdown": true,
                "join_all_threads": true,
                "timeout_sec": 5
            }
        }
    },
    "api_contract": {
        "architecture_style": "layered + hexagonal",

        "layers": {
            "application": ["core"],
            "interface": ["ui"],
            "infrastructure": ["system", "utils"],
            "security": ["security"],
            "configuration": ["config"]
        },

        "dependency_rules": [
            "ui -> core only",
            "core -> system + security + utils",
            "system -> utils only",
            "security -> utils only",
            "config -> no dependency",
            "forbid_reverse_dependency",
            "forbid_circular_dependency"
        ],

        "module_boundaries": {
            "core": {
                "allowed_dependencies": [
                    "system",
                    "security",
                    "utils",
                    "config"
                ],
                "exposed_interfaces": [
                    "engine_api",
                    "monitor_api",
                    "state_api"
                ],
                "internal_only": ["state_machine", "decision_logic"]
            },
            "ui": {
                "allowed_dependencies": ["core", "utils"],
                "exposed_interfaces": ["overlay_api"],
                "internal_only": ["window_management", "input_handling"]
            },
            "security": {
                "allowed_dependencies": ["utils"],
                "exposed_interfaces": ["auth_api", "encryption_api"],
                "internal_only": ["hashing_impl", "memory_zeroing"]
            },
            "system": {
                "allowed_dependencies": ["utils"],
                "exposed_interfaces": [
                    "process_api",
                    "service_api",
                    "hook_api"
                ],
                "internal_only": ["win32_bindings"]
            },
            "utils": {
                "allowed_dependencies": [],
                "exposed_interfaces": ["logger_api", "time_api", "error_api"]
            },
            "config": {
                "allowed_dependencies": ["utils"],
                "exposed_interfaces": ["config_api"],
                "internal_only": ["env_loader", "validator"]
            }
        },

        "interface_rules": {
            "use_traits_for_abstraction": true,
            "no_concrete_dependency_between_modules": true,
            "prefer_trait_injection": true,
            "interfaces_must_be_defined_before_implementation": true,
            "each_module_must_expose_public_api_layer": true
        },

        "dependency_injection": {
            "required": true,
            "type": "constructor_injection",
            "rules": [
                "no_global_singletons",
                "inject_dependencies_explicitly",
                "allow_mocking_for_tests"
            ]
        },

        "data_flow": {
            "direction": "unidirectional",
            "rules": [
                "ui -> core -> system",
                "no_direct_ui_to_system_access",
                "no_shared_mutable_state_outside_appstate",
                "events_must_use_channel"
            ]
        },

        "event_contract": {
            "communication_pattern": "message_passing",
            "event_types_required": [
                "ProcessDetected",
                "ProcessBlocked",
                "OverlayRequested",
                "UnlockSuccess",
                "UnlockFailed",
                "ShutdownRequested",
                "EmergencyUnlock"
            ],
            "rules": [
                "events_must_be_enum",
                "no_string_based_events",
                "must_handle_all_event_variants",
                "no_unhandled_match_case"
            ]
        },

        "state_access_rules": {
            "global_state_access": "controlled",
            "rules": [
                "state_mutation_only_via_core",
                "no_direct_write_from_ui",
                "use_read_write_lock_correctly",
                "validate_state_before_update"
            ]
        },

        "error_propagation_contract": {
            "strategy": "Result<T, E>",
            "rules": [
                "no_error_swallowing",
                "all_errors_must_have_context",
                "use_custom_error_types",
                "convert_external_errors"
            ]
        },

        "versioning": {
            "api_versioning": true,
            "strategy": "semantic",
            "rules": [
                "no_breaking_change_without_version_bump",
                "maintain_backward_compatibility"
            ]
        },

        "extensibility": {
            "plugin_ready": true,
            "rules": [
                "use_trait_based_extension",
                "no_hardcoded_logic_in_core",
                "allow_future_detection_modules"
            ]
        },

        "testability": {
            "mocking_required": true,
            "rules": [
                "all_external_dependencies_must_be_mockable",
                "no_hardcoded_paths",
                "no_direct_env_access_in_core",
                "use_trait_for_system_calls"
            ]
        },

        "performance_contract": {
            "rules": [
                "no_blocking_calls_in_core_loop",
                "minimize_lock_contention",
                "prefer_event_driven_over_polling",
                "avoid_unnecessary_allocations"
            ]
        }
    },
    "developer_experience": {
        "debugging": {
            "log_levels": ["info", "warn", "error", "debug"],
            "enable_backtrace": true
        },
        "code_style": {
            "enforced_by": ["rustfmt", "clippy"],
            "deny_warnings": true
        }
    },
    "compile_time_guards": {
        "enforce_trait_usage": true,
        "deny_direct_struct_usage_across_modules": true,
        "require_interface_layer": true
    },
    "runtime_flow": {
        "startup_sequence": [
            "load_env",
            "validate_env_permissions",
            "load_config",
            "validate_config_schema",
            "initialize_logger",
            "initialize_global_state",
            "check_single_instance_lock",
            "apply_startup_delay",
            "enter_monitoring_state"
        ],
        "main_loop": {
            "state_machine": {
                "Monitoring": [
                    "scan_processes",
                    "apply_validation_delay",
                    "apply_behavior_scoring",
                    "check_whitelist",
                    "check_blacklist",
                    "if_detected -> transition_to_Blocking"
                ],
                "Blocking": [
                    "validate_process_safe_to_kill",
                    "apply_kill_policy",
                    "terminate_process",
                    "verify_process_terminated",
                    "update_state(is_safe_to_block=true, is_locked=true)",
                    "send_event_to_ui",
                    "transition_to_Locked"
                ],
                "Locked": [
                    "launch_overlay",
                    "start_overlay_watchdog",
                    "wait_for_unlock_event",
                    "handle_authentication",
                    "if_success -> transition_to_Recovering",
                    "if_fail -> enforce_backoff"
                ],
                "Recovering": [
                    "ensure_no_blocked_process_running",
                    "cleanup_resources",
                    "reset_state(is_safe_to_block=false, is_locked=false)",
                    "log_recovery_event",
                    "transition_to_Monitoring"
                ],
                "SafeMode": [
                    "disable_blocking",
                    "log_safe_mode",
                    "monitor_only_no_action",
                    "wait_for_manual_recovery"
                ]
            }
        },
        "event_flow": {
            "tx_to_rx": [
                "process_detected",
                "blocking_triggered",
                "overlay_requested"
            ],
            "rx_to_tx": [
                "unlock_success",
                "unlock_failed",
                "force_shutdown",
                "emergency_unlock"
            ]
        },
        "failure_flow": {
            "on_process_kill_failure": [
                "retry_with_backoff",
                "if_exceeded -> log_failure",
                "transition_to_SafeMode"
            ],
            "on_overlay_crash": [
                "reset_is_locked_false",
                "log_overlay_crash",
                "restart_overlay_or_exit"
            ],
            "on_thread_panic": [
                "catch_unwind",
                "log_thread_failure",
                "restart_thread"
            ],
            "on_deadlock_detected": [
                "log_deadlock",
                "restart_component",
                "if_repeated -> SafeMode"
            ],
            "on_channel_disconnect": [
                "recreate_channel",
                "log_channel_error",
                "if_failed -> SafeMode"
            ]
        },
        "shutdown_flow": [
            "receive_shutdown_signal",
            "stop_monitor_thread",
            "stop_ui_thread",
            "cleanup_resources",
            "flush_logs",
            "release_lock_file",
            "exit_gracefully"
        ]
    },
    "lifecycle_hooks": {
        "on_start": ["validate_config", "initialize_logging", "warmup_monitor"],
        "on_block_detected": ["log_event", "kill_process", "trigger_overlay"],
        "on_unlock": ["reset_state", "write_report", "resume_monitor"],
        "on_shutdown": ["flush_logs", "join_threads", "cleanup_resources"]
    },
    "student_mode_policy": {
        "enabled": true,
        "restrictions": [
            "disable_task_manager",
            "disable_registry_tools",
            "disable_cmd"
        ],
        "apply_only_when_locked": true,
        "restore_on_unlock": true
    },
    "game_blocking_policy": {
        "enabled": true,
        "mode": "schedule_based",
        "block_during_school_hours_only": true,

        "schedule": {
            "timezone": "Asia/Jakarta",
            "rules": [
                {
                    "days": [
                        "Monday",
                        "Tuesday",
                        "Wednesday",
                        "Thursday",
                        "Friday"
                    ],
                    "start": "07:00",
                    "end": "15:00",
                    "action": "block_games"
                },
                {
                    "days": ["Saturday"],
                    "start": "07:00",
                    "end": "12:00",
                    "action": "block_games"
                }
            ]
        },

        "outside_schedule_behavior": {
            "allow_games": true,
            "monitor_only": true
        }
    },
    "process_control": {
        "behavior_scoring": {
            "enabled": true,
            "score_threshold": 70,
            "weights": {
                "cpu_spike": 15,
                "rapid_spawn": 20,
                "suspicious_path": 25,
                "hidden_process": 20,
                "renamed_exe": 30
            },
            "actions": {
                "low_score": "monitor",
                "medium_score": "flag",
                "high_score": "block"
            }
        },
        "behavior_detection": {
            "enabled": true,
            "rules": [
                {
                    "type": "high_gpu_usage",
                    "threshold_percent": 60,
                    "duration_seconds": 10,
                    "action": "flag_suspicious"
                },
                {
                    "type": "child_process_spawn",
                    "pattern": "launcher_to_game",
                    "action": "trace_and_block"
                },
                {
                    "type": "hidden_process",
                    "condition": "no_window_high_cpu",
                    "action": "flag"
                }
            ],

            "on_suspicious": ["log_event", "increase_monitoring_frequency"]
        },
        "game_detection": {
            "blocked_games": [
                {
                    "name": "Roblox",
                    "process_names": ["RobloxPlayerBeta.exe"],
                    "paths": [
                        "C:\\Program Files (x86)\\Roblox\\",
                        "C:\\Users\\*\\AppData\\Local\\Roblox\\"
                    ]
                },
                {
                    "name": "Valorant",
                    "process_names": ["VALORANT-Win64-Shipping.exe"],
                    "paths": ["C:\\Riot Games\\VALORANT\\"]
                },
                {
                    "name": "Steam",
                    "process_names": ["steam.exe"],
                    "paths": ["C:\\Program Files (x86)\\Steam\\"]
                },
                {
                    "name": "Epic Games",
                    "process_names": ["EpicGamesLauncher.exe"],
                    "paths": ["C:\\Program Files (x86)\\Epic Games\\"]
                }
            ],

            "watch_paths": [
                "C:\\Program Files",
                "C:\\Program Files (x86)",
                "C:\\Users",
                "C:\\ProgramData",
                "D:\\Games"
            ],

            "extensions": [".exe", ".lnk"]
        },
        "monitoring": {
            "library": "sysinfo",
            "interval": "configurable",
            "validation_delay_ms": [300, 1000]
        },
        "kill_policy": {
            "grace_period_seconds": [1, 2],
            "rate_limit_per_minute": 3,
            "checks": [
                "cpu_state",
                "process_stability",
                "parent_chain",
                "not_system_owned"
            ],
            "on_violation": ["skip_kill", "log_unsafe_to_kill"]
        },
        "protected_processes": [
            "System",
            "winlogon.exe",
            "csrss.exe",
            "smss.exe",
            "services.exe",
            "lsass.exe",
            "explorer.exe"
        ]
    },
    "failure_modes": {
        "overlay_failure": {
            "action": "release_lock_and_exit"
        },
        "monitor_failure": {
            "action": "restart_thread"
        },
        "config_corruption": {
            "action": "fallback_last_known_good"
        },
        "auth_system_failure": {
            "action": "deny_all_access"
        },
        "log_failure": {
            "action": "fallback_memory_buffer"
        }
    },
    "cli_interface": {
        "commands": [
            {
                "name": "reset-password",
                "description": "Reset admin password"
            },
            {
                "name": "status",
                "description": "Show current state"
            },
            {
                "name": "disable",
                "description": "Emergency disable blocker"
            }
        ]
    },
    "config": {
        "hot_reload": true,
        "safe_reload": true,
        "debounce_ms": 500,
        "reload_strategy": "safe_swap",
        "watch_config_file": true,
        "on_reload_failure": [
            "rollback_previous_config",
            "log_config_reload_error"
        ],
        "schema_validation": {
            "enabled": true,
            "fail_on_invalid": true,
            "use_strict_types": true,
            "validate_on_startup": true,
            "validate_on_reload": true,
            "strict_schema": true,
            "reject_unknown_fields": true,
            "fallback_on_error": "last_known_good"
        },
        "config_management": {
            "supported_formats": ["json", "toml", "yaml"],
            "priority_order": [
                "env",
                "runtime_override",
                "config_file",
                "default"
            ]
        }
    },
    "overlay": {
        "framework": "Win32 API (windows crate)",
        "behavior": {
            "fullscreen": true,
            "topmost": true,
            "focus_interval_ms": 500,
            "block_keys": ["Alt+F4", "Escape"]
        },
        "display": {
            "title": "Peringatan Keamanan",
            "message": "Aplikasi terlarang terdeteksi dan telah ditutup.",
            "fields": ["process_name", "pid", "username", "timestamp"],
            "footer": "This program was developed by Muhamad Fahmi, Assistant Head of the Computer Lab."
        },
        "safety": {
            "failsafe_timeout_minutes": 30,
            "on_crash": ["reset_state", "log_overlay_crash_recovery"]
        },
        "overlay_ui_enhancement": {
            "theme": {
                "background_color": "#0f172a",
                "primary_color": "#ef4444",
                "text_color": "#f8fafc",
                "accent_color": "#22c55e",
                "font": "Segoe UI"
            },

            "layout": {
                "centered_box": true,
                "box_width_percent": 40,
                "rounded_corners": true,
                "shadow": true
            },

            "animations": {
                "fade_in": true,
                "shake_on_error": true,
                "button_hover_effect": true
            },

            "content": {
                "title": "⚠️ Peringatan Keamanan",
                "message": "Aplikasi terlarang terdeteksi dan telah dihentikan oleh sistem.",
                "sub_message": "Silakan masukkan kata sandi administrator untuk membuka akses.",
                "footer": "This program was developed by Muhamad Fahmi, Assistant Head of the Computer Lab."
            },

            "extra_features": {
                "show_attempt_counter": true,
                "show_time": true,
                "show_pc_name": true,
                "show_block_reason": true
            }
        }
    },
    "security": {
        "authentication": {
            "algorithms": ["Argon2", "PBKDF2"],
            "source": ".env",
            "features": [
                "max_attempts",
                "exponential_backoff",
                "lockout_duration",
                "memory_zeroing"
            ]
        },
        "env": {
            "validate_permissions": true,
            "environment_validation": true
        },
        "integrity": {
            "config_hash_check": true,
            "on_change": ["reload_safe", "enter_safe_mode"]
        },
        "anti_bypass_hardening": {
            "self_protection": {
                "prevent_termination": true,
                "detect_kill_attempt": true,
                "on_kill_attempt": ["log_intrusion", "restart_process"]
            },
            "process_obfuscation": {
                "randomize_internal_identifiers": true
            },
            "binary_integrity": {
                "self_hash_check": true,
                "on_tamper": ["shutdown_safely", "log_tamper_event"]
            }
        },
        "thread_health": {
            "heartbeat_interval_ms": 1000,
            "max_missed_heartbeat": 5,
            "on_thread_unresponsive": ["restart_thread", "log_thread_failure"]
        },
        "whitelist": {
            "priority_over_blacklist": true,
            "rules": ["path_match", "hash_match", "publisher_match"]
        },
        "deadlock_detection": {
            "enabled": true,
            "timeout_ms": 5000,
            "on_detected": ["log_deadlock", "restart_component"]
        },
        "secure_storage": {
            "use_dpapi": true,
            "encrypt_env_values": true,
            "protect_config_file": true
        },
        "anti_debugging": {
            "detect_debugger": true,
            "on_detected": ["log_event", "enter_safe_mode"]
        },
        "privilege_escalation_protection": {
            "validate_execution_context": true,
            "prevent_unauthorized_elevation": true
        }
    },
    "credential_management": {
        "password_reset": {
            "enabled": true,
            "method": "cli_tool",
            "command": "app_blocker --reset-password",
            "requires_admin": true,
            "logs_event": true
        },
        "storage": {
            "source": ".env",
            "allow_override": true,
            "encryption_optional": true
        },
        "validation": {
            "min_length": 8,
            "require_complexity": false
        }
    },
  "anti_bypass_rules": {
    "detect_renamed_executable": true,
    "detect_portable_games": true,
    "detect_usb_execution": true,
    "on_detect": [
      "kill_process",
      "trigger_overlay",
      "log_critical"
    ]
  },
    "threat_model": {
        "threats": [
            "process_spoofing",
            "privilege_escalation",
            "config_tampering",
            "binary_replacement",
            "debugger_attach",
            "memory_dump_attack"
        ],
        "mitigations": [
            "verify_process_signature",
            "validate_parent_process",
            "use_dpapi_for_secrets",
            "self_integrity_check",
            "anti_debugging",
            "secure_memory_handling"
        ]
    },
    "observability": {
        "metrics": {
            "enabled": true,
            "track": [
                "process_scanned",
                "process_killed",
                "overlay_triggered",
                "auth_attempt",
                "error_count"
            ]
        },
        "health_check": {
            "endpoint": false,
            "internal_check_interval_sec": 10
        },
        "debug_mode": {
            "structured_logs": true,
            "trace_id": true
        }
    },
    "logging": {
        "path": "C:\\AppBlocker\\reports",
        "format": [
            "timestamp",
            "process_info",
            "action",
            "unlock_attempts",
            "username"
        ],
        "method": "atomic_write",
        "rotation": {
            "enabled": true,
            "retention_days": 7,
            "no_delete_active_file": true
        },
        "fallback": "memory_buffer",
        "telemetry": {
            "enabled": true,
            "collect": [
                "event_frequency",
                "error_types",
                "kill_success_rate",
                "unlock_success_rate"
            ],
            "export_format": "json"
        },
        "observability": {
            "structured_logging": true,
            "log_levels": ["ERROR", "WARN", "INFO", "DEBUG"],
            "correlation_id": true,
            "trace_id": true,
            "event_tracing": true
        },
        "report_enhancement": {
            "include": [
                "blocked_game_name",
                "session_duration_before_kill",
                "detection_method",
                "schedule_rule_triggered"
            ],
            "format": "json_pretty",
            "compression": false
        }
    },
    "debugging": {
        "debug_mode": {
            "enabled": true,
            "verbose_logging": true,
            "include_internal_state": true
        },
        "diagnostics": {
            "thread_dump_on_error": true,
            "state_dump_on_failure": true,
            "log_last_known_state": true
        },
        "crash_report": {
            "enabled": true,
            "include_stacktrace": true,
            "include_thread_info": true
        }
    },
    "system_safety": {
        "startup": {
            "delay_seconds": [15, 30],
            "validate_config": true,
            "on_invalid": "enter_safe_mode"
        },
        "failure_handling": {
            "threshold": 5,
            "on_exceed": ["disable_blocking", "enter_recovery_mode"]
        },
        "thread_safety": {
            "panic_protection": "catch_unwind",
            "restart_on_failure": true
        },
        "resource_limits": {
            "max_cpu_usage_percent": 20,
            "max_memory_mb": 200,
            "on_exceed": ["throttle_monitoring", "log_resource_warning"]
        },
        "dev_safety": {
            "require_confirmation_before_kill": true,
            "simulate_overlay": true,
            "disable_real_kill_in_dev": true,
            "log_all_simulations": true
        },
        "rollback": {
            "enabled": true,
            "checkpoint_on_start": true,
            "restore_on_crash": true,
            "max_checkpoints": 3,
            "levels": ["config", "state", "process_control"],
            "on_failure": [
                "restore_last_known_good",
                "disable_blocking",
                "enter_safe_mode"
            ]
        },
        "failsafe": {
            "global_disable_flag": "C:\\AppBlocker\\disable",
            "check_interval_ms": 2000,
            "on_trigger": [
                "stop_all_blocking",
                "stop_all_blocking",
                "enter_safe_mode",
                "log_failsafe_triggered"
            ]
        },
        "fast_fail": {
            "enabled": true,
            "critical_error_types": [
                "state_corruption",
                "deadlock_detected",
                "channel_disconnected"
            ],
            "on_trigger": ["shutdown_gracefully", "log_critical_failure"]
        },
        "memory_security": {
            "zero_on_drop": true,
            "protect_sensitive_buffers": true,
            "avoid_heap_for_secrets": true
        },
        "instance_control": {
            "single_instance": true,
            "lock_file": "C:\\AppBlocker\\app.lock",
            "on_duplicate": ["exit_new_instance", "log_duplicate_launch"]
        },
        "self_healing": {
            "enabled": true,
            "strategies": ["restart_component", "reset_state", "fallback_mode"],
            "max_retries": 3
        },
        "performance": {
            "adaptive_scan_interval": true,
            "dynamic_throttling": true,
            "backpressure_handling": true
        },
        "global_timeout": {
            "enabled": true,
            "max_operation_seconds": 10,
            "on_timeout": ["abort_operation", "log_timeout"]
        },
        "resource_isolation": {
            "cpu_priority": "below_normal",
            "io_priority": "low",
            "thread_limits": 10,
            "memory_guard": {
                "max_mb": 200,
                "kill_on_exceed": false,
                "throttle_on_exceed": true
            }
        }
    },
    "shortcuts": {
        "emergency_unlock": true,
        "force_shutdown": true,
        "requirements": ["works_under_overlay", "log_usage"]
    },
    "service": {
        "compatibility": ["Task Scheduler", "NSSM"],
        "auto_restart": {
            "enabled": true,
            "delay_seconds": 5,
            "max_retry": "configurable"
        }
    },
    "testing": {
        "unit": ["auth", "engine", "state"],
        "integration": [
            "kill_loop",
            "overlay_failure",
            "mutex_contention",
            "channel_failure"
        ],
        "fuzz": ["invalid_config", "corrupted_env"],
        "chaos_testing": {
            "enabled": true,
            "scenarios": [
                "kill_random_thread",
                "simulate_high_cpu",
                "simulate_memory_leak",
                "simulate_io_failure"
            ]
        },
        "load_testing": {
            "max_processes_simulated": 500,
            "stress_duration_seconds": 300
        }
    },
    "execution_mode": {
        "deterministic": true,
        "fail_on_missing_requirement": true
    },
    "code_generation_strategy": {
        "phases": [
            "analyze_requirements",
            "design_architecture",
            "define_interfaces",
            "implement_modules",
            "apply_error_handling",
            "apply_security_rules",
            "validate_thread_safety",
            "run_self_review"
        ],
        "rules": [
            "no_direct_full_dump_without_planning",
            "must_define_structs_before_usage",
            "must_define_errors_first",
            "must_define_state_machine_first"
        ]
    },
    "linting_pipeline": {
        "required": [
            "cargo fmt --check",
            "cargo clippy -- -D warnings",
            "cargo audit",
            "cargo deny"
        ]
    },
    "ci_cd": {
        "github_actions": {
            "enabled": true,
            "workflows": ["build", "test", "lint", "security_audit", "release"],
            "pipelines": {
                "build": ["cargo check --all-targets", "cargo build --release"],
                "test": ["cargo test --all", "cargo test --release"],
                "lint": ["cargo fmt -- --check", "cargo clippy -- -D warnings"],
                "security": ["cargo audit", "cargo deny check"]
            },
            "artifacts": {
                "build_binary": true,
                "compress": "zip",
                "include": ["app_blocker.exe"]
            },
            "release": {
                "tag_version": true,
                "generate_changelog": true
            }
        }
    },
    "code_rules": {
        "no_panic": true,
        "no_unwrap": true,
        "no_unsafe": true,
        "error_handling": ["Result", "thiserror", "anyhow"],
        "style": [
            "idiomatic_rust",
            "clear_naming",
            "modular_design",
            "ownership_correct"
        ],
        "comments": "Bahasa Indonesia",
        "forbidden_patterns": [
            "unwrap",
            "expect",
            "panic!",
            "todo!",
            "unimplemented!"
        ],
        "clippy_enforcement": {
            "deny": [
                "clippy::unwrap_used",
                "clippy::expect_used",
                "clippy::panic",
                "clippy::todo",
                "clippy::unimplemented",
                "clippy::indexing_slicing",
                "clippy::wildcard_imports"
            ]
        },
        "error_handling_policy": {
            "no_silent_failures": true,
            "all_errors_must_be_logged": true,
            "error_context_required": true,
            "use_error_propagation": true
        },
        "logging_rules": {
            "log_levels": ["INFO", "WARN", "ERROR", "CRITICAL"],
            "no_sensitive_data_logging": true,
            "structured_logging": true,
            "include_trace_id": true
        },
        "naming_conventions": {
            "functions": "snake_case",
            "variables": "snake_case",
            "structs": "PascalCase",
            "constants": "UPPER_CASE"
        },
        "modularity_rules": {
            "max_function_length_lines": 100,
            "max_file_length_lines": 1000,
            "single_responsibility": true,
            "no_god_module": true
        },
        "memory_safety_rules": {
            "no_leaking_handles": true,
            "drop_resources_explicitly": true,
            "zero_sensitive_buffers": true
        },
        "concurrency_rules": {
            "no_deadlocks": true,
            "lock_timeout_required": true,
            "prefer_message_passing": true,
            "no_shared_mutation_without_lock": true
        },
        "performance_rules": {
            "avoid_unnecessary_allocations": true,
            "avoid_blocking_calls_in_hot_path": true,
            "use_lazy_initialization": true
        },
        "testability_rules": {
            "dependency_injection": true,
            "mockable_components": true,
            "no_hardcoded_paths": true
        },
        "documentation_rules": {
            "all_public_functions_documented": true,
            "include_examples": true,
            "explain_unsafe_if_used": true,
            "language": "Bahasa Indonesia"
        }
    },
    "output": {
        "format": "multi_file / per file",
        "extentions": [
            "rs",
            "md",
            "lock",
            "tolm",
            "log",
            "gitignore",
            "env",
            "ps1",
            "yaml",
            "sh"
        ],
        "separator": "===== filename.rs =====",
        "include": ["Cargo.toml", "README.md", "CHANGELOG.md"]
    }
}
