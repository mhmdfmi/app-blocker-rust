{
  "_comment": "Format: tambah BANYAK aplikasi ke whitelist - digunakan untuk tool pendidikan lab komputer",
  "_usage": "app_blocker.exe add-whitelist --file whitelist_bulk.json",
  "_version": "1.0",

  "entries": [

    {
      "name": "Visual Studio Code",
      "process_names": ["Code.exe"],
      "paths": ["C:\\Program Files\\Microsoft VS Code\\"],
      "description": "Editor kode utama untuk praktikum"
    },

    {
      "name": "Microsoft Visual Studio",
      "process_names": ["devenv.exe"],
      "paths": [
        "C:\\Program Files\\Microsoft Visual Studio\\",
        "C:\\Program Files (x86)\\Microsoft Visual Studio\\"
      ],
      "description": "IDE Visual Studio untuk mata kuliah pemrograman"
    },

    {
      "name": "Android Studio",
      "process_names": ["studio64.exe", "studio.exe"],
      "paths": [
        "C:\\Program Files\\Android\\Android Studio\\"
      ],
      "description": "IDE untuk praktikum pengembangan Android"
    },

    {
      "name": "NetBeans IDE",
      "process_names": ["netbeans64.exe", "netbeans.exe"],
      "paths": [
        "C:\\Program Files\\NetBeans-*\\"
      ],
      "description": "IDE NetBeans untuk praktikum Java"
    },

    {
      "name": "XAMPP",
      "process_names": ["xampp-control.exe", "httpd.exe", "mysqld.exe"],
      "paths": [
        "C:\\xampp\\"
      ],
      "description": "Web server lokal untuk praktikum web"
    },

    {
      "name": "WampServer",
      "process_names": ["wampmanager.exe"],
      "paths": [
        "C:\\wamp64\\",
        "C:\\wamp\\"
